EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Google OAuth — create credentials at console.cloud.google.com → APIs & Services → Credentials
# Web client ID is required for Expo Go; iOS/Android IDs needed for native builds (EAS)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# Translation: 'google' (free, default) | 'gemini' (requires API key) | 'none'
TRANSLATE_PROVIDER=google
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
# Client-side AI plan generation (EXPO_PUBLIC prefix = bundled into app)
EXPO_PUBLIC_GEMINI_API_KEY=
