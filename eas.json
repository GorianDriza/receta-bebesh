{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "environment": "production",
      "distribution": "internal",
      "autoIncrement": true,
      "channel": "production"
    },
    "production-ios": {
      "environment": "production",
      "distribution": "store",
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "production": {},
    "production-ios": {
      "ios": {
        "appleId": "goriandriza11@gmail.com",
        "ascAppId": "",
        "appleTeamId": ""
      }
    }
  }
}
